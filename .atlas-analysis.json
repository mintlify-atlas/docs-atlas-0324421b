  "keyFeatures": [
    "Multi-platform container deployment (Docker, Kubernetes, ECS, EKS, App Runner)",
    "Microservices architecture with 5 independent services (UI, Catalog, Cart, Orders, Checkout)",
    "Multiple persistence backends (MySQL, DynamoDB, PostgreSQL, Redis, in-memory)",
    "Prometheus metrics and OpenTelemetry OTLP tracing instrumentation",
    "Generative AI chatbot via Amazon Bedrock and OpenAI-compatible endpoints",
    "Chaos engineering utility endpoints for resilience testing",
    "Pre-built multi-arch container images (x86-64 and ARM64)",
    "Terraform modules for AWS deployment (EKS, ECS, App Runner)",
    "Istio service mesh support on Kubernetes",
    "Load generator for stress testing and autoscaling demos"
  ],
  "publicApiSurface": [
    "GET /catalog/products — List products with filtering and pagination",
    "GET /catalog/products/{id} — Get product by ID",
    "GET /catalog/tags — List all product tags",
    "GET /catalog/size — Get catalog size",
    "POST /cart — Create or update shopping cart",
    "GET /cart/{customerId} — Get customer cart",
    "DELETE /cart/{customerId} — Delete customer cart",
    "POST /orders — Create a new order",
    "GET /orders — List orders",
    "POST /checkout — Initiate checkout session",
    "GET /utility/status/{code} — Return specific HTTP status code",
    "GET /utility/headers — Echo request headers",
    "GET /utility/panic — Trigger application shutdown",
    "POST /chaos/status/{code} — Inject HTTP status code errors",
    "POST /chaos/latency/{delay} — Inject response latency",
    "POST /chaos/health — Cause health checks to fail"
  ]
}
